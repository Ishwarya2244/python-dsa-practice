

# ----------------------------------------------------------
# Program 1: Binary Search - Element Found
# ----------------------------------------------------------

print("Program 1: Element Found")

numbers = [5, 10, 15, 20, 25, 30, 35]
target = 25

left = 0
right = len(numbers) - 1

while left <= right:
    mid = (left + right) // 2

    if numbers[mid] == target:
        print("Element found at index", mid)
        break

    elif target > numbers[mid]:
        left = mid + 1

    else:
        right = mid - 1

print()


